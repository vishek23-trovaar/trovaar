{
  "expo": {
    "name": "Trovaar",
    "slug": "trovaar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "trovaar",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2563eb",
      "resizeMode": "contain",
      "image": "./assets/splash.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trovaar.app",
      "buildNumber": "13",
      "infoPlist": {
        "NSCameraUsageDescription": "Trovaar uses your camera to take photos of jobs you want to post.",
        "NSPhotoLibraryUsageDescription": "Trovaar uses your photo library to attach images to job postings.",
        "NSLocationWhenInUseUsageDescription": "Trovaar uses your location to find nearby contractors.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Trovaar uses your location to find nearby contractors."
      },
      "config": {
        "usesNonExemptEncryption": false,
        "googleMapsApiKey": "AIzaSyDCHOBlfhWEv6mzXV68rEW117xWr0VFfhs"
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDCHOBlfhWEv6mzXV68rEW117xWr0VFfhs"
        }
      },
      "package": "com.trovaar.app",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Trovaar uses your photo library to attach images to job postings.",
          "cameraPermission": "Trovaar uses your camera to take photos of jobs you want to post."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "6ec5e52e-08be-486e-83ef-6f630649627d"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "vishek23",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6ec5e52e-08be-486e-83ef-6f630649627d"
    }
  }
